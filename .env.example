# =========================================================
# LLM provider — pick one (groq or openai). Default: groq (free tier).
# =========================================================
LLM_PROVIDER=groq

# ---- Groq (free, fast Llama models) ----
# Get a key at https://console.groq.com (free tier, no credit card)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JUDGE_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ---- OpenAI (alternative, paid) ----
# Only required if LLM_PROVIDER=openai or if EMBEDDINGS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_JUDGE_MODEL=gpt-4o

LLM_TEMPERATURE=0.0

# =========================================================
# Embeddings — local by default (no key needed).
# =========================================================
# `local` uses ChromaDB's bundled ONNX MiniLM (~80MB, downloaded once).
# `openai` uses text-embedding-3-small (slightly better recall, requires OPENAI_API_KEY).
EMBEDDINGS_PROVIDER=local

# =========================================================
# Web search — Tavily has a free tier (1k requests/month).
# Get a key at https://tavily.com -> Settings -> API Keys.
# =========================================================
TAVILY_API_KEY=tvly-...

# =========================================================
# Redis (use redis://redis:6379 inside Docker, redis://localhost:6379 locally)
# Falls back to in-memory if unavailable.
# =========================================================
REDIS_URL=redis://localhost:6379

# =========================================================
# Server
# =========================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# =========================================================
# Frontend
# =========================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =========================================================
# Agent
# =========================================================
AGENT_VERSION=v2
CONFIDENCE_THRESHOLD=0.55

# =========================================================
# Vector store
# =========================================================
CHROMA_PERSIST_DIR=./data/chroma
LABOR_CODE_PDF_URL=https://www.act.gov.pt/(pt-PT)/Legislacao/Legislacao_n/Documents/C%C3%B3digo%20do%20Trabalho.pdf
